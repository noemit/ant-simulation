# OpenAI-compatible LLM provider.
# For Cerebras, use a tool-capable, fast model such as:
#   LLM_BASE_URL=https://api.cerebras.ai/v1
#   LLM_MODEL=llama-4-maverick-17b-128e-instruct
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Simulation scale.
ANT_COUNT=40

# LLM refresh cadence.
# All ants are sent in a single request. The physics tick never waits on the LLM.
# A new request is fired every LLM_DECISION_INTERVAL_MS milliseconds.
LLM_DECISION_INTERVAL_MS=500
LLM_TIMEOUT_MS=10000
LLM_BATCH_TIMEOUT_MS=10000
LLM_MAX_RETRIES=0

# Simulation
PORT=3000
